@page "/"
@using UserManager.Models
@using UserManager.Services
@using UserManager.Components.Shared
@inject IUserService UserService
@inject NavigationManager Nav

<PageTitle>Pulpit · UserManager</PageTitle>

<div class="page-head">
    <div>
        <h1>Pulpit</h1>
        <p>Przegląd bazy użytkowników i szybki dostęp do zarządzania.</p>
    </div>
    <button class="btn btn-primary" @onclick="@(() => Nav.NavigateTo("/users/new"))">
        + Dodaj użytkownika
    </button>
</div>

@if (_loading)
{
    <p class="text-muted">Wczytywanie…</p>
}
else
{
    <div class="stats">
        <div class="stat-card accent">
            <div class="label">Wszyscy użytkownicy</div>
            <div class="value">@_stats.Total</div>
        </div>
        <div class="stat-card ok">
            <div class="label">Aktywni</div>
            <div class="value">@_stats.Active</div>
        </div>
        <div class="stat-card">
            <div class="label">Nieaktywni</div>
            <div class="value">@_stats.Inactive</div>
        </div>
    </div>

    <div class="card-panel">
        <div class="toolbar">
            <strong style="font-size:.95rem;">Ostatnio dodani</strong>
            <span style="flex:1"></span>
            <a class="btn btn-ghost btn-sm" href="/users">Zobacz wszystkich</a>
        </div>

        @if (_recent.Count == 0)
        {
            <div class="empty">
                <div class="glyph">
                    <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
                </div>
                <h3>Brak użytkowników</h3>
                <p>Dodaj pierwszego użytkownika, aby rozpocząć.</p>
                <a class="btn btn-primary" href="/users/new">+ Dodaj użytkownika</a>
            </div>
        }
        else
        {
            <table class="user-table">
                <thead>
                    <tr>
                        <th>Użytkownik</th>
                        <th class="hide-sm">Dział</th>
                        <th class="hide-sm">Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in _recent)
                    {
                        <tr style="cursor:pointer" @onclick="@(() => Nav.NavigateTo($"/users/{user.Id}/edit"))">
                            <td>
                                <div class="user-cell">
                                    <UserAvatar Name="@user.FullName" />
                                    <div>
                                        <div class="name">@user.FullName</div>
                                        <div class="email">@user.Email</div>
                                    </div>
                                </div>
                            </td>
                            <td class="hide-sm"><span class="tag">@user.Department.ToPolish()</span></td>
                            <td class="hide-sm">
                                @if (user.IsActive)
                                {
                                    <span class="badge-status on">Aktywny</span>
                                }
                                else
                                {
                                    <span class="badge-status off">Nieaktywny</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
}

@code {
    private bool _loading = true;
    private UserStats _stats = new(0, 0, 0);
    private List<User> _recent = new();

    protected override async Task OnInitializedAsync()
    {
        _stats = await UserService.GetStatsAsync();
        _recent = (await UserService.GetAllAsync()).Take(5).ToList();
        _loading = false;
    }
}
